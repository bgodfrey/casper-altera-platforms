From d7241192eba1d5c7188e696c809568934bedf076 Mon Sep 17 00:00:00 2001
From: "Ben G." <bgodfrey@berkeley.edu>
Date: Mon, 8 Jun 2026 13:30:16 -0700
Subject: [PATCH 1/3] arm: dts: enable SoCFPGA FPGA manager and bridges

---
 arch/arm/boot/dts/intel/socfpga/socfpga.dtsi | 9 +++++----
 1 file changed, 5 insertions(+), 4 deletions(-)

diff --git a/arch/arm/boot/dts/intel/socfpga/socfpga.dtsi b/arch/arm/boot/dts/intel/socfpga/socfpga.dtsi
index 35be14150f41..630c2f6f6601 100644
--- a/arch/arm/boot/dts/intel/socfpga/socfpga.dtsi
+++ b/arch/arm/boot/dts/intel/socfpga/socfpga.dtsi
@@ -528,7 +528,7 @@ fpga_bridge0: fpga_bridge@ff400000 {
 			reg = <0xff400000 0x100000>;
 			resets = <&rst LWHPS2FPGA_RESET>;
 			clocks = <&l4_main_clk>;
-			status = "disabled";
+			status = "okay";
 		};
 
 		fpga_bridge1: fpga_bridge@ff500000 {
@@ -536,7 +536,7 @@ fpga_bridge1: fpga_bridge@ff500000 {
 			reg = <0xff500000 0x10000>;
 			resets = <&rst HPS2FPGA_RESET>;
 			clocks = <&l4_main_clk>;
-			status = "disabled";
+			status = "okay";
 		};
 
 		fpga_bridge2: fpga-bridge@ff600000 {
@@ -544,13 +544,13 @@ fpga_bridge2: fpga-bridge@ff600000 {
 			reg = <0xff600000 0x100000>;
 			resets = <&rst FPGA2HPS_RESET>;
 			clocks = <&l4_main_clk>;
-			status = "disabled";
+			status = "okay";
 		};
 
 		fpga_bridge3: fpga-bridge@ffc25080 {
 			compatible = "altr,socfpga-fpga2sdram-bridge";
 			reg = <0xffc25080 0x4>;
-			status = "disabled";
+			status = "okay";
 		};
 
 		fpgamgr0: fpgamgr@ff706000 {
@@ -558,6 +558,7 @@ fpgamgr0: fpgamgr@ff706000 {
 			reg = <0xff706000 0x1000
 			       0xffb90000 0x4>;
 			interrupts = <0 175 4>;
+			status="okay";
 		};
 
 		socfpga_axi_setup: stmmac-axi-config {
-- 
